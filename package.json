{
  "name": "yoctomarkdown",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^5.86.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "yoctocolors": "^2.1.2"
  },
  "bin": {
    "yoctomarkdown": "./cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "jscpd": "jscpd . --ignore \"node_modules/**\"",
    "check": "bun run typecheck && bun run knip && bun run jscpd",
    "prepare": "husky"
  }
}
