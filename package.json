{
  "name": "yoctomarkdown",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^5.86.0",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "yoctocolors": "^2.1.2"
  },
  "bin": {
    "yoctomarkdown": "./src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "jscpd": "jscpd . --ignore \"node_modules/**\"",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run knip && bun run jscpd",
    "prepare": "husky",
    "lint": "biome lint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test"
  }
}
